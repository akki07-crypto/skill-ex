{
  "name": "learn",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "nodemon --exec ts-node server/server.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "start": "node server-dist/server/server.js",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "mongoose": "^9.7.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "oxlint": "^1.71.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
